# Database — SQLite for local dev (default). For PostgreSQL, change the
# provider in prisma/schema.prisma to "postgresql" and use a postgres URL.
DATABASE_URL="file:./dev.db"

# Auth.js
AUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Backblaze B2 (S3-compatible) — profile photo storage
B2_ENDPOINT="https://s3.<region>.backblazeb2.com"
B2_REGION="<region>"            # e.g. eu-central-003
B2_BUCKET="<bucket-name>"
B2_BUCKET_ID="<bucket-id>"
B2_KEY_ID="<application-key-id>"
B2_APP_KEY="<application-key>"

# Application
NODE_ENV="development"
