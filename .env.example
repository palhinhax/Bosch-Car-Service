# Database — SQLite for local dev (default). For PostgreSQL, change the
# provider in prisma/schema.prisma to "postgresql" and use a postgres URL.
DATABASE_URL="file:./dev.db"

# Auth.js
AUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Application
NODE_ENV="development"
